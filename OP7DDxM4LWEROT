RunService.RenderStepped:Connect(function()
    if fovCirculo then fovCirculo.Position = UserInputService:GetMouseLocation() end
    if aimbotAtivo and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
        local camera = workspace.CurrentCamera
        local alvo = nil
        local menorDist = fovRaio
        for _, v in pairs(players:GetPlayers()) do
            if v ~= player and v.Character and v.Character:FindFirstChild(alvoParte) then
                local pos, vis = camera:WorldToViewportPoint(v.Character[alvoParte].Position)
                if vis then
                    local mag = (Vector2.new(pos.X, pos.Y) - UserInputService:GetMouseLocation()).Magnitude
                    if mag < menorDist then menorDist = mag alvo = v end
                end
            end
        end
        if alvo then camera.CFrame = CFrame.new(camera.CFrame.Position, alvo.Character[alvoParte].Position) end
    end
end)


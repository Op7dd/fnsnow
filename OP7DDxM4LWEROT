    Main.Position = UDim2.new(0.5, -150, 0.5, -75)
    Main.BackgroundColor3 = Color3.fromRGB(64,64,64)

    TextBox.Size = UDim2.new(0, 200, 0, 40)
    TextBox.Position = UDim2.new(0.5, -100, 0.3, 0)
    TextBox.PlaceholderText = "Enter Key..."
    TextBox.Text = ""

    Submit.Size = UDim2.new(0, 100, 0, 30)
    Submit.Position = UDim2.new(0.5, -50, 0.7, 0)
    Submit.Text = "Submit"
    Submit.BackgroundColor3 = Color3.fromRGB(64,64,64)
    Submit.TextColor3 = Color3.new(255, 255, 255)

  Submit.MouseButton1Click:Connect(function()
        if TextBox.Text == KeySystem.Key then
            KeySystem.Status = true
            
            -- NOTIFICAÇÃO DE SUCESSO
            game:GetService("StarterGui"):SetCore("SendNotification", {
                Title = "Acesso Permitido",
                Text = "Você acessou o Sexy Hub com sucesso, seja bem-vindo: " .. game.Players.LocalPlayer.Name,
                Duration = 5,
                Icon = "rbxassetid://12296859791" -- Ícone opcional de check
            })

            ScreenGui:Destroy()
        else
            TextBox.Text = ""
            TextBox.PlaceholderText = "WRONG KEY!"
            task.wait(1)
            TextBox.PlaceholderText = "Enter Key..."
        end
    end)

    repeat task.wait() until KeySystem.Status == true
end


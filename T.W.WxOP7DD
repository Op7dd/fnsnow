btnTema.TextColor3 = Color3.new(1, 1, 1)
btnTema.Font = Enum.Font.GothamBold
Instance.new("UICorner", btnTema)

btnTema.MouseButton1Click:Connect(function()
    local nome = proximoTema()
    btnTema.Text = "Tema Atual: " .. nome
end)


-- 2. LÓGICA DO BOTÃO
TriggerBtn.MouseButton1Click:Connect(function()
    triggerBotEnabled = not triggerBotEnabled
    TriggerBtn.Text = "Trigger Bot: " .. (triggerBotEnabled and "ON" or "OFF")
    TriggerBtn.BackgroundColor3 = triggerBotEnabled and Color3.fromRGB(30, 150, 30) or Color3.fromRGB(150, 30, 30)
end)



-- 3. LOOP "RAIZ" (O QUE FUNCIONAVA)
task.spawn(function()
    while task.wait(0.01) do 
        if triggerBotEnabled and not minimizado then
            local mouse = player:GetMouse()
            local t = mouse.Target
            
            if t and t.Parent then
                -- Checagem direta: O pai do que eu toquei tem um Humanoid?
                local char = t.Parent
                if char:FindFirstChild("Humanoid") then
                    local targetPlayer = game.Players:GetPlayerFromCharacter(char)
                    
                    -- Se for player, não for você e estiver vivo
                    if targetPlayer and targetPlayer ~= player and char.Humanoid.Health > 0 then
                        -- Clique simples (O executor precisa suportar isso)
                        if mouse1click then 
                            mouse1click() 
                        elseif mouse1press then
                            mouse1press()
                            task.wait(0.01)
                            mouse1release()
                        end
                        task.wait(0.2) -- Delay para não travar a arma
                    end
                end
            end
        end
    end
end)

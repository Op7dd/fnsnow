local minimizado = false

MinimizeBtn.MouseButton1Click:Connect(function()
    minimizado = not minimizado
    
    -- Se Footer existir, muda a visibilidade
    if Footer then
        Footer.Visible = not minimizado
    end

    local targetSize = minimizado and UDim2.new(0, 75, 0, 45) or UDim2.new(0, 550, 0, 380)
    local tweenInfo = TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
    TweenService:Create(MainFrame, tweenInfo, {Size = targetSize}):Play()
    
    -- Esconde o resto
    Sidebar.Visible = not minimizado
    ContentContainer.Visible = not minimizado
    
    MinimizeBtn.Text = minimizado and "+" or "-"
end)


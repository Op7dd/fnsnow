-- --- SISTEMA DE ABAS ---
local abas = {}

local function criarAba(nome)
    -- Botão na Sidebar
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, 35)
    btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    btn.Text = nome
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 14
    btn.Parent = Sidebar
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

    -- Scrolling Frame da Aba
    local scrol = Instance.new("ScrollingFrame")
    scrol.Name = nome.."_Page"
    scrol.Size = UDim2.new(1, -10, 1, -10)
    scrol.Position = UDim2.new(0, 5, 0, 5)
    scrol.BackgroundTransparency = 1
    scrol.CanvasSize = UDim2.new(0, 0, 2, 0) -- Permite scroll longo
    scrol.ScrollBarThickness = 3
    scrol.Visible = false
    scrol.Parent = ContentContainer

    local scrolLayout = Instance.new("UIListLayout")
    scrolLayout.Padding = UDim.new(0, 8)
    scrolLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    scrolLayout.Parent = scrol

    btn.MouseButton1Click:Connect(function()
        for _, a in pairs(abas) do a.Visible = false end
        scrol.Visible = true
    end)

    abas[nome] = scrol
    return scrol
end

-- Criando as abas
local AbaFarm = criarAba("FARM")
local AbaMovement = criarAba("MOVEMENT")
local AbaCombat = criarAba("COMBAT")
local AbaConfig = criarAba("CONFIG")

AbaFarm.Visible = true -- Começa na aba Farm

-- --- BOTÃO DE KEYBIND (NA ABA CONFIG) ---
local KeybindBtn = Instance.new("TextButton")
KeybindBtn.Size = UDim2.new(0.9, 0, 0, 40)
KeybindBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
KeybindBtn.Text = "Menu Key: " .. toggleKey.Name
KeybindBtn.TextSize = 16
KeybindBtn.TextColor3 = Color3.new(1, 1, 1)
KeybindBtn.Font = Enum.Font.GothamBold
KeybindBtn.Parent = AbaConfig
Instance.new("UICorner", KeybindBtn)

KeybindBtn.MouseButton1Click:Connect(function()
    waitingForKey = true
    KeybindBtn.Text = "Press any key..."
end)

-- --- LÓGICA DE INPUT (TOGGLE UI E KEYBIND) ---
UserInputService.InputBegan:Connect(function(input, gpe)
    if waitingForKey and input.UserInputType == Enum.UserInputType.Keyboard then
        toggleKey = input.KeyCode
        KeybindBtn.Text = "Menu Key: " .. toggleKey.Name
        waitingForKey = false
        return
    end

    if not gpe and input.KeyCode == toggleKey then
        menuVisible = not menuVisible
        MainFrame.Visible = menuVisible
    end
end)

local function proximoTema()
    temaAtual = temaAtual + 1
    if temaAtual > #ListaTemas then temaAtual = 1 end -- Reseta para o 1
    
    local t = ListaTemas[temaAtual]
    local info = TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)

    -- Anima o fundo principal e o container
    TweenService:Create(MainFrame, info, {BackgroundColor3 = t.Main}):Play()
    TweenService:Create(ContentContainer, info, {BackgroundColor3 = t.Content}):Play()

    -- Anima todos os botões da Sidebar
    for _, obj in pairs(Sidebar:GetChildren()) do
        if obj:IsA("TextButton") then
            TweenService:Create(obj, info, {BackgroundColor3 = t.Accent}):Play()
        end
    end
    
    return t.Nome -- Retorna o nome para atualizar o texto do botão
end

local btnTema = Instance.new("TextButton", AbaConfig)
btnTema.Size = UDim2.new(0.9, 0, 0, 40)
btnTema.Text = "Tema Atual: Escuro"

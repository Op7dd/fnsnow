local abas = {}

local function novaAba(nome)

    local frameAba = Instance.new("ScrollingFrame")
    frameAba.Size = UDim2.new(1, 0, 1, 0)
    frameAba.BackgroundTransparency = 1
    frameAba.Visible = false
    frameAba.ScrollBarThickness = 2
    frameAba.CanvasSize = UDim2.new(0, 0, 2, 0)
    frameAba.Parent = contentHolder

    local layout = Instance.new("UIListLayout")
    layout.Padding = UDim.new(0, 10)
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.Parent = frameAba

    local btnAba = Instance.new("TextButton")
    btnAba.Size = UDim2.new(0.9, 0, 0, 40)
    btnAba.BackgroundColor3 = Color3.fromRGB(172, 10, 10)
    btnAba.Text = nome
    btnAba.TextColor3 = Color3.new(1, 1, 1)
    btnAba.Font = Enum.Font.SourceSansBold
    btnAba.TextSize = 16
    btnAba.Parent = sidebar
    Instance.new("UICorner", btnAba).CornerRadius = UDim.new(0, 8)

    btnAba.MouseButton1Click:Connect(function()
        for _, v in pairs(abas) do v.Visible = false end
        frameAba.Visible = true
    end)

    abas[nome] = frameAba
    return frameAba
end

